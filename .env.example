# ============================================================
#  AI Generation API — пример окружения. Скопируй в .env
# ============================================================

APP_ENV=local                       # local | staging | production
LOG_LEVEL=INFO

# --- Generation provider (движок генерации на GPU) ---
# mock    — без GPU, для разработки и интеграции (рисует заглушку)
# comfyui — реальный ComfyUI на GPU-сервере
GENERATION_PROVIDER=mock
COMFYUI_URL=http://localhost:8188
COMFYUI_TIMEOUT=600
COMFYUI_POLL_INTERVAL=0.5

# --- Безопасность контента (проверка 21+ ПЕРЕД генерацией, анти-CSAM) ---
# none       — выключено (только для локальной разработки!)
# mock       — тестовая: блокирует, если metadata.simulate_minor=true
# insightface — реальная оценка возраста по лицу (нужны insightface+onnxruntime, GPU)
SAFETY_PROVIDER=mock
SAFETY_MIN_AGE=21
SAFETY_FAIL_CLOSED=true

# --- База данных (PostgreSQL) ---
DATABASE_URL=postgresql+psycopg://genapi:genapi@localhost:5432/genapi

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Конфиги режимов и моделей ---
MODES_DIR=./config/modes
WORKFLOWS_DIR=./config/workflows
MODELS_CONFIG=./config/models.yaml

# --- Хранилище: local | s3 | r2 | minio ---
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=./storage
PUBLIC_BASE_URL=http://localhost:8000
# S3 / R2 / MinIO (если STORAGE_PROVIDER != local):
S3_ENDPOINT_URL=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# --- Очередь / надёжность ---
TASK_SOFT_TIMEOUT=540               # сек, мягкий таймаут задачи
TASK_HARD_TIMEOUT=600               # сек, жёсткий таймаут задачи
TASK_MAX_RETRIES=3
CALLBACK_MAX_RETRIES=5

# --- Безопасность ---
API_KEY_HEADER=X-API-Key
WEBHOOK_SIGNING_SECRET=change-me-in-production   # HMAC подпись callback'ов
INTERNAL_JWT_SECRET=change-me-too                # internal service tokens

# --- Rate limit (запросов в окне) ---
RATE_LIMIT_PER_API_KEY=120          # за окно
RATE_LIMIT_PER_USER=60
RATE_LIMIT_PER_IP=240
RATE_LIMIT_WINDOW_SECONDS=60
